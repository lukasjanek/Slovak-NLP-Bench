{
  "builds": [
    { "src": "api/tasks.py",       "use": "@vercel/python" },
    { "src": "api/leaderboard.py", "use": "@vercel/python" },
    { "src": "api/model.py",       "use": "@vercel/python" },
    { "src": "static/**",          "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/tasks",                   "dest": "/api/tasks.py" },
    { "src": "/api/leaderboard/([^/]+)",     "dest": "/api/leaderboard.py" },
    { "src": "/api/model/(.+)",              "dest": "/api/model.py" },
    { "src": "/leaderboard.html",            "dest": "/static/leaderboard.html" },
    { "src": "/model.html",                  "dest": "/static/model.html" },
    { "src": "/css/(.*)",                    "dest": "/static/css/$1" },
    { "src": "/js/(.*)",                     "dest": "/static/js/$1" },
    { "src": "/",                            "dest": "/static/index.html" }
  ]
}
